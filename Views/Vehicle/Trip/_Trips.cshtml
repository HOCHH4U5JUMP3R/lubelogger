@using System.Globalization
@using CarCareTracker.Helper
@inject IConfigHelper config
@inject ITranslationHelper translator
@model List<Note>
@{
    var userConfig = config.GetUserConfig(User);
    var userLanguage = userConfig.UserLanguage;
    var enableCsvImports = userConfig.EnableCsvImports;

    string ParseDescriptionValue(string description, int index)
    {
        if (string.IsNullOrWhiteSpace(description))
        {
            return "---";
        }
        var split = description.Split(':', 2);
        var datePart = split[0].Trim();
        if (index == 0)
        {
            return string.IsNullOrWhiteSpace(datePart) ? "---" : datePart;
        }
        if (split.Length < 2)
        {
            return "---";
        }
        var routeParts = split[1].Split("->", 2);
        if (index == 1)
        {
            return routeParts.Length > 0 && !string.IsNullOrWhiteSpace(routeParts[0]) ? routeParts[0].Trim() : "---";
        }

        return routeParts.Length > 1 && !string.IsNullOrWhiteSpace(routeParts[1]) ? routeParts[1].Trim() : "---";
    }

    string ParseNoteValue(string noteText, string fieldPrefix)
    {
        if (string.IsNullOrWhiteSpace(noteText))
        {
            return "---";
        }
        var lines = noteText.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        var line = lines.FirstOrDefault(x => x.StartsWith(fieldPrefix, StringComparison.OrdinalIgnoreCase));
        if (string.IsNullOrWhiteSpace(line))
        {
            return "---";
        }
        var value = line.Split(':', 2).LastOrDefault()?.Trim();
        return string.IsNullOrWhiteSpace(value) ? "---" : value;
    }

    double ParseNumericTripValue(string noteText, string fieldPrefix)
    {
        var raw = ParseNoteValue(noteText, fieldPrefix);
        if (string.IsNullOrWhiteSpace(raw) || raw == "---")
        {
            return 0;
        }

        var normalized = raw.Replace(',', '.');
        return double.TryParse(normalized, NumberStyles.Any, CultureInfo.InvariantCulture, out var parsed) ? parsed : 0;
    }

    var totalDistanceKm = Model.Sum(x => ParseNumericTripValue(x.NoteText, "Distance (km)"));
    var totalDurationSeconds = Model.Sum(x => ParseNumericTripValue(x.NoteText, "Duration (s)"));
}
<div class="d-flex flex-column vehicleTabPane">
    <div class="row">
        <div class="d-flex justify-content-between">
            <div class="d-flex align-items-center flex-wrap gap-2">
                <span class="badge bg-success">@($"{translator.Translate(userLanguage, "# of Trips")}: {Model.Count}")</span>
                <span class="badge bg-primary">@($"Total Distance: {totalDistanceKm.ToString("F2", CultureInfo.InvariantCulture)} km")</span>
                <span class="badge bg-primary">@($"Total Duration: {TimeSpan.FromSeconds(totalDurationSeconds):dd\\:hh\\:mm\\:ss}")</span>
            </div>
            <div class="lubelogger-record-add">
                <div class="btn-group">
                    <button onclick="showAddTripModal()" class="btn btn-primary btn-md mt-1 mb-1"><i class="bi bi-pencil-square me-2"></i>@translator.Translate(userLanguage, "Add Trip")</button>
                    <button type="button" class="btn btn-md btn-primary btn-md mt-1 mb-1 dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="visually-hidden">Toggle Dropdown</span>
                    </button>
                    <ul class="dropdown-menu record-dropdown">
                        @if (enableCsvImports)
                        {
                            <li>
                                <label class="dropdown-item mb-0" style="cursor:pointer;">
                                    @translator.Translate(userLanguage, "Import via CSV")
                                    <input type="file" accept=".csv" class="d-none" onchange="importTripsCsv(this)" />
                                </label>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                        }
                        <li><a class="dropdown-item" href="#" onclick="printTab()">@translator.Translate(userLanguage, "Print")</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row vehicleDetailTabContainer flex-grow-1">
        <div class="col-12">
            <table class="table table-hover @(userConfig.UseGridInMobile ? "" : "ll-responsive-table")">
                <thead class="sticky-top">
                    <tr class="d-flex">
                        <th scope="col" class="col-2 flex-grow-1 text-truncate">Date</th>
                        <th scope="col" class="col-2 flex-grow-1 text-truncate">Start Location</th>
                        <th scope="col" class="col-2 flex-grow-1 text-truncate">End Location</th>
                        <th scope="col" class="col-1 flex-grow-1 text-truncate">Distance (km)</th>
                        <th scope="col" class="col-1 flex-grow-1 text-truncate">Duration (s)</th>
                        <th scope="col" class="col-1 flex-grow-1 text-truncate">Avg Speed (km/h)</th>
                        <th scope="col" class="col-1 flex-grow-1 text-truncate">Max Speed (km/h)</th>
                        <th scope="col" class="col-1 flex-grow-1 text-truncate">Max Altitude (m)</th>
                        <th scope="col" class="col-1 flex-grow-1 text-truncate">Elevation Gain (m)</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var trip in Model)
                        {
                            <tr class="d-flex user-select-none" style="cursor:pointer;" onclick="showEditTripModal(@trip.Id)">
                                <td class="col-2 flex-grow-1 text-truncate" data-label="Date">@ParseDescriptionValue(trip.Description, 0)</td>
                                <td class="col-2 flex-grow-1 text-truncate" data-label="Start Location">@ParseDescriptionValue(trip.Description, 1)</td>
                                <td class="col-2 flex-grow-1 text-truncate" data-label="End Location">@ParseDescriptionValue(trip.Description, 2)</td>
                                <td class="col-1 flex-grow-1 text-truncate" data-label="Distance (km)">@ParseNoteValue(trip.NoteText, "Distance (km)")</td>
                                <td class="col-1 flex-grow-1 text-truncate" data-label="Duration (s)">@ParseNoteValue(trip.NoteText, "Duration (s)")</td>
                                <td class="col-1 flex-grow-1 text-truncate" data-label="Avg Speed (km/h)">@ParseNoteValue(trip.NoteText, "Avg Speed (km/h)")</td>
                                <td class="col-1 flex-grow-1 text-truncate" data-label="Max Speed (km/h)">@ParseNoteValue(trip.NoteText, "Max Speed (km/h)")</td>
                                <td class="col-1 flex-grow-1 text-truncate" data-label="Max Altitude (m)">@ParseNoteValue(trip.NoteText, "Max Altitude (m)")</td>
                                <td class="col-1 flex-grow-1 text-truncate" data-label="Elevation Gain (m)">@ParseNoteValue(trip.NoteText, "Elevation Gain (m)")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr class="d-flex">
                            <td class="col-12 text-center text-muted py-4">@translator.Translate(userLanguage, "No trips found")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
