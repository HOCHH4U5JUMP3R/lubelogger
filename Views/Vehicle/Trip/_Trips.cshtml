@using CarCareTracker.Helper
@inject IConfigHelper config
@inject ITranslationHelper translator
@model List<Note>
@{
    var userConfig = config.GetUserConfig(User);
    var userLanguage = userConfig.UserLanguage;
    var enableCsvImports = userConfig.EnableCsvImports;
}
<div class="d-flex flex-column vehicleTabPane">
    <div class="row">
        <div class="d-flex justify-content-between">
            <div class="d-flex align-items-center flex-wrap gap-2">
                <span class="badge bg-success">@($"{translator.Translate(userLanguage, "# of Trips")}: {Model.Count}")</span>
            </div>
            <div class="lubelogger-record-add">
                <div class="btn-group">
                    <button onclick="showAddTripModal()" class="btn btn-primary btn-md mt-1 mb-1"><i class="bi bi-pencil-square me-2"></i>@translator.Translate(userLanguage, "Add Trip")</button>
                    <button type="button" class="btn btn-md btn-primary btn-md mt-1 mb-1 dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="visually-hidden">Toggle Dropdown</span>
                    </button>
                    <ul class="dropdown-menu record-dropdown">
                        @if (enableCsvImports)
                        {
                            <li>
                                <label class="dropdown-item mb-0" style="cursor:pointer;">
                                    @translator.Translate(userLanguage, "Import via CSV")
                                    <input type="file" accept=".csv" class="d-none" onchange="importTripsCsv(this)" />
                                </label>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                        }
                        <li><a class="dropdown-item" href="#" onclick="printTab()">@translator.Translate(userLanguage, "Print")</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="row vehicleDetailTabContainer flex-grow-1">
        <div class="col-12">
            <table class="table table-hover @(userConfig.UseGridInMobile ? "" : "ll-responsive-table")">
                <thead class="sticky-top">
                    <tr class="d-flex">
                        <th scope="col" class="col-2 flex-grow-1 text-truncate">@translator.Translate(userLanguage, "Description")</th>
                        <th scope="col" class="col-8 flex-grow-1 text-truncate">@translator.Translate(userLanguage, "Notes")</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var trip in Model)
                        {
                            <tr class="d-flex user-select-none" style="cursor:pointer;" onclick="showEditTripModal(@trip.Id)">
                                <td class="col-2 flex-grow-1 text-truncate" data-label="@translator.Translate(userLanguage, "Description")">@(string.IsNullOrWhiteSpace(trip.Description) ? "---" : trip.Description)</td>
                                <td class="col-8 flex-grow-1 text-truncate" data-label="@translator.Translate(userLanguage, "Notes")">@(string.IsNullOrWhiteSpace(trip.NoteText) ? "---" : trip.NoteText)</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr class="d-flex">
                            <td class="col-12 text-center text-muted py-4">@translator.Translate(userLanguage, "No trips found")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
